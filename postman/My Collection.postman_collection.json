    {
      "name": "Saucedemo API Tests",
      "request": {
        "method": "GET",
        "header": []
      },
      "response": []
    },
    {
      "name": ": Login - Valid User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains 10 users\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.length).to.equal(10);\r",
              "});\r",
              "\r",
              "pm.test(\"Each user has id, name and email\", function () {\r",
              "    const json = pm.response.json();\r",
              "    json.forEach(function(user) {\r",
              "        pm.expect(user).to.have.property('id');\r",
              "        pm.expect(user).to.have.property('name');\r",
              "        pm.expect(user).to.have.property('email');\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
